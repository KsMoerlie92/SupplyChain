{
  "version": 2,
  "builds": [
    { "src": "api/douane.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/douane", "dest": "/api/douane.js" },
    { "src": "/(.*)",       "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
