{
  "routes": [
    {
      "route": "/po-matcher",
      "rewrite": "/po-matcher/index.html"
    },
    {
      "route": "/legplan",
      "rewrite": "/legplan/index.html"
    },
    {
      "route": "/",
      "rewrite": "/index.html"
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  },
  "globalHeaders": {
    "X-Frame-Options": "ALLOWALL",
    "Content-Security-Policy": "frame-ancestors 'self' https://*.sharepoint.com https://teams.microsoft.com https://*.teams.microsoft.com https://*.office.com",
    "Access-Control-Allow-Origin": "*",
    "Access-Control-Allow-Methods": "GET, OPTIONS",
    "Access-Control-Allow-Headers": "Content-Type"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".js":   "application/javascript",
    ".css":  "text/css"
  }
}
